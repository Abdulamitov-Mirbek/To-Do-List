{
  "name": "todolist-api",
  "version": "1.0.0",
  "description": "REST API для To-Do List приложения",
  "main": "server.js",
  "scripts": {
    "postinstall": "node ./node_modules/prisma/build/index.js generate",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node ./node_modules/prisma/build/index.js migrate dev",
    "prisma:seed": "node prisma/seed.js",
    "prisma:studio": "node ./node_modules/prisma/build/index.js studio",
    "migrate:deploy": "node ./node_modules/prisma/build/index.js migrate deploy",
    "test": "echo \"Тесты будут добавлены\" && exit 0"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.4",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "prisma": "^5.7.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": "20.x"
  }
}
